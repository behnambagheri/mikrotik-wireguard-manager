# Multi-router profiles (recommended)
# Format:
# ProfileName={ user=..., password=..., router_ip=..., endpoint_ip=..., dns_servers=..., transport=rest|api_ssl|api, use_https=false, timeout_sec=30 }

Novin_Max={ user=YOUR_USER, password=CHANGE_ME, router_ip=172.16.40.1, endpoint_ip=YOUR_PUBLIC_IP, dns_servers=YOUR_DNS_SERVERS_COMMA_SEPARATED_OR_ROUTER_IP, transport=rest, use_https=false, timeout_sec=30 }
Office_Max={ user=YOUR_USER, password=CHANGE_ME, router_ip=192.168.10.1, endpoint_ip=YOUR_PUBLIC_IP, dns_servers=YOUR_DNS_SERVERS_COMMA_SEPARATED_OR_ROUTER_IP, transport=rest, use_https=false, timeout_sec=30 }
Asiatech_LAP={ user=YOUR_USER, password=CHANGE_ME, router_ip=172.25.50.1, endpoint_ip=YOUR_PUBLIC_IP, dns_servers=YOUR_DNS_SERVERS_COMMA_SEPARATED_OR_ROUTER_IP, transport=api, timeout_sec=30 }

# Legacy single-router mode (still supported)
# ROUTER_IP=172.16.40.1
# ROUTER_USER=bea
# ROUTER_PASS=CHANGE_ME
# ROUTER_USE_HTTPS=false
# ROUTER_TIMEOUT_SEC=30
# ENDPOINT_IP=77.74.202.60
# DNS_SERVERS=100.100.100.100,100.100.100.101

# Optional CLI env overrides
# WG_TUI_ENV_FILE=.env
# WG_TUI_STATE_FILE=.wg_tui_state.json
